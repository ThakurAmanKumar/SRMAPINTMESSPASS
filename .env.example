# ===================================
# SRMAP Mess Pass Portal - Environment Variables
# ===================================
# Copy this file to .env.local and fill in your actual values
# NEVER commit .env.local to version control!

# ===================================
# API Configuration
# ===================================
# For development: http://localhost:3000
# For production: https://yourdomain.vercel.app
NEXT_PUBLIC_API_URL=https://yourdomain.vercel.app

# ===================================
# MongoDB Atlas Configuration
# ===================================
# Format: mongodb+srv://username:password@cluster.mongodb.net/?appName=SRMAPIMPASS
# Get this from MongoDB Atlas > Connect > Connection String
MONGODB_URI=mongodb+srv://your_username:your_password@your-cluster.mongodb.net/?appName=SRMAPIMPASS

# ===================================
# JWT Configuration
# ===================================
# Generate a strong JWT secret (32+ characters)
# Command: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_very_secure_jwt_secret_key_at_least_32_characters_long

# ===================================
# SMTP Configuration (Gmail)
# ===================================
# Gmail requires App Password: https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-16-character-app-password

# ===================================
# Admin Configuration
# ===================================
# Comma-separated list of admin emails
ADMIN_EMAIL=admin@srmapimpass.com

# ===================================
# Cloudinary Configuration (Optional)
# ===================================
# For image uploads via Cloudinary
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
